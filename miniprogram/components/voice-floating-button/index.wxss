.voice-floating-wrap {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: calc(108rpx + env(safe-area-inset-bottom));
  z-index: 999;
}

.voice-floating-button {
  width: 136rpx;
  height: 136rpx;
  border-radius: 42rpx;
  position: relative;
  overflow: visible;
  background: linear-gradient(135deg, rgba(255, 206, 220, 0.72), rgba(255, 126, 161, 0.48));
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  box-shadow: 0 18rpx 42rpx rgba(255, 106, 149, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx);
  transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease;
}

.voice-floating-button.recording {
  transform: scale(1.08);
  box-shadow: 0 24rpx 52rpx rgba(255, 106, 149, 0.36);
  animation: breath 1.25s ease-in-out infinite;
}

.voice-floating-button.cancel {
  background: linear-gradient(135deg, rgba(255, 168, 176, 0.84), rgba(240, 90, 112, 0.72));
  border-color: rgba(255, 233, 237, 0.9);
  animation: none;
}

.voice-overlay {
  position: absolute;
  inset: 0;
  border-radius: 42rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.02));
}

.voice-glass {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 10rpx;
  height: 42rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.04));
  opacity: 0.9;
}

.voice-icon {
  position: relative;
  z-index: 2;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-icon-image {
  width: 72rpx;
  height: 72rpx;
}

.icon-close {
  width: 48rpx;
  height: 48rpx;
}

.close-line {
  position: absolute;
  left: 22rpx;
  top: 4rpx;
  width: 4rpx;
  height: 40rpx;
  background: #ffffff;
  border-radius: 2rpx;
}

.close-line-a {
  transform: rotate(45deg);
}

.close-line-b {
  transform: rotate(-45deg);
}

.pulse-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 148rpx;
  height: 148rpx;
  border-radius: 46rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.44);
  transform: translate(-50%, -50%) scale(1);
  opacity: 0;
  pointer-events: none;
}

.ring-a {
  animation: ripple 1.4s ease-out infinite;
}

.ring-b {
  animation: ripple 1.4s ease-out 0.7s infinite;
}

.voice-mask {
  position: fixed;
  inset: 0;
  background: rgba(7, 16, 28, 0);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}

.voice-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.voice-panel {
  position: absolute;
  left: 50%;
  bottom: calc(290rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%) scale(0.96);
  width: 420rpx;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(12, 20, 34, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.22);
  color: #ffffff;
  text-align: center;
  opacity: 0.94;
  transition: background-color 180ms ease, transform 180ms ease, opacity 180ms ease;
}

.voice-mask.show .voice-panel {
  transform: translateX(-50%) scale(1);
  opacity: 1;
}

.voice-panel.cancel {
  background: rgba(205, 65, 90, 0.94);
}

.voice-title {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 18rpx;
}

.voice-bars {
  height: 52rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 10rpx;
}

.bar {
  width: 10rpx;
  min-height: 12rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.92);
}

@keyframes breath {
  0%, 100% {
    transform: scale(1.06);
  }
  50% {
    transform: scale(1.11);
  }
}

@keyframes ripple {
  0% {
    transform: translate(-50%, -50%) scale(0.95);
    opacity: 0.55;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.35);
    opacity: 0;
  }
}

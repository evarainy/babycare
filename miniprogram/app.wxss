page {
  background:
    radial-gradient(circle at top left, rgba(255, 210, 224, 0.56), transparent 32%),
    linear-gradient(180deg, #fff7fb 0%, #fffdfd 32%, #f8fbff 100%);
  background-color: #fff8fb;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #253042;
}

button {
  padding: 0;
  line-height: normal;
  background: transparent;
}

button::after {
  border: none;
}

.container {
  padding: 0 32rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 148, 174, 0.14);
  box-shadow: 0 16rpx 40rpx rgba(255, 148, 174, 0.12);
  box-sizing: border-box;
}

.btn-primary,
.btn-secondary {
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease;
}

.btn-primary {
  background: linear-gradient(135deg, #ff8fa8 0%, #ff6a95 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(255, 106, 149, 0.28);
}

.btn-primary:active,
.btn-secondary:active {
  transform: scale(0.98);
}

.btn-secondary {
  background: #fff4f8;
  color: #b45175;
  border: 1rpx solid rgba(255, 143, 171, 0.22);
}

.text-primary {
  color: #ff7198;
}

.text-gray {
  color: #7e8b9d;
}

.text-small {
  font-size: 24rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #253042;
  margin-bottom: 24rpx;
}

.section-kicker {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #b84f77;
  background: rgba(255, 143, 171, 0.14);
}

.section-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7e8b9d;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 88rpx 40rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx dashed rgba(255, 143, 171, 0.22);
  color: #9aa6b6;
  box-sizing: border-box;
}

.empty-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #c95e82;
  background: linear-gradient(135deg, rgba(255, 143, 171, 0.16), rgba(255, 200, 214, 0.28));
  margin-bottom: 18rpx;
}

.empty-state text {
  font-size: 28rpx;
  margin-top: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.tag-pink {
  background: #fff0f5;
  color: #c9557d;
}

.tag-blue {
  background: #eef5ff;
  color: #3c79d8;
}

.tag-green {
  background: #eefbf2;
  color: #2f9a63;
}

.tag-orange {
  background: #fff5e9;
  color: #da8b28;
}

.type-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
}

.type-badge.breastfeeding,
.type-badge.bottle {
  background: linear-gradient(135deg, #ff8fa8, #ff6a95);
}

.type-badge.food {
  background: linear-gradient(135deg, #ffb347, #ff8a3d);
}

.type-badge.supplement {
  background: linear-gradient(135deg, #36c8b3, #1ea592);
}

.type-badge.medicine {
  background: linear-gradient(135deg, #ff7f7c, #ef5350);
}

.type-badge.outdoor {
  background: linear-gradient(135deg, #9ad96a, #f2b44a);
}

.type-badge.swimming {
  background: linear-gradient(135deg, #5faeff, #4277ff);
}

.type-badge.diaper {
  background: linear-gradient(135deg, #57c089, #2ea85b);
}

.type-badge.sleep {
  background: linear-gradient(135deg, #9d8cff, #7265f7);
}

.type-badge.other {
  background: linear-gradient(135deg, #8f9db4, #68758b);
}

.page-dark {
  background:
    radial-gradient(circle at top left, rgba(255, 143, 171, 0.12), transparent 34%),
    linear-gradient(180deg, #141c29 0%, #101722 100%);
}

.page-dark .card {
  background: rgba(25, 35, 52, 0.94);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

.page-dark .section-title,
.page-dark .section-copy,
.page-dark .text-gray,
.page-dark .text-small {
  color: #c9d3e3 !important;
}

.page-dark .section-kicker {
  background: rgba(255, 143, 171, 0.18);
  color: #ffd6e1;
}

.page-dark .empty-state {
  background: rgba(25, 35, 52, 0.92);
  border-color: rgba(255, 255, 255, 0.1);
  color: #9aa6b6;
}

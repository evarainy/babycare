.page {
  min-height: 100vh;
}

.profile-page {
  padding-top: 28rpx;
  padding-bottom: 48rpx;
}

.loading-card {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #7e8b9d;
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, rgba(255, 151, 180, 0.14), rgba(255, 210, 90, 0.12));
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 34rpx;
  background: #fff4f8;
}

.avatar-edit {
  position: absolute;
  left: 50%;
  bottom: -14rpx;
  transform: translateX(-50%);
  min-width: 120rpx;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(37, 48, 66, 0.78);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.profile-copy {
  flex: 1;
}

.profile-kicker {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 143, 171, 0.14);
  color: #be5279;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-title {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #253042;
  font-weight: 600;
}

.form-card {
  margin-top: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-grid {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #425066;
}

.form-input,
.picker-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  border: 2rpx solid #eef1f6;
  background: #fbfcff;
  color: #253042;
  font-size: 28rpx;
}

.form-input,
.picker-input {
  min-height: 92rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.form-textarea {
  min-height: 180rpx;
  padding: 22rpx 24rpx;
  line-height: 1.6;
}

.placeholder {
  color: #a1adbd;
}

.gender-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.gender-pill {
  min-width: 156rpx;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff4f8;
  color: #c44d77;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.gender-pill.active {
  background: linear-gradient(135deg, #ff8fa8, #ff6a95);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(255, 106, 149, 0.2);
}

.submit-btn {
  margin-top: 12rpx;
}

.page-dark .profile-hero {
  background: linear-gradient(135deg, rgba(255, 143, 171, 0.16), rgba(255, 208, 90, 0.12));
}

.page-dark .avatar-edit {
  background: rgba(12, 18, 28, 0.82);
}

.page-dark .loading-text,
.page-dark .form-label,
.page-dark .profile-title {
  color: #eef2fb;
}

.page-dark .form-input,
.page-dark .picker-input,
.page-dark .form-textarea,
.page-dark .gender-pill {
  background: #111825;
  border-color: rgba(255, 255, 255, 0.12);
  color: #eef2fb;
}

.page-dark .placeholder {
  color: #8e9bb0;
}

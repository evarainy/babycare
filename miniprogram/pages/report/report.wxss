.page {
  padding: 24rpx 32rpx 168rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.period-selector {
  display: flex;
  gap: 10rpx;
  padding: 10rpx;
  margin-bottom: 24rpx;
}

.period-btn {
  flex: 1;
  height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #667387;
  display: flex;
  align-items: center;
  justify-content: center;
}

.period-btn.active {
  background: linear-gradient(135deg, #ff8fa8, #ff6a95);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(255, 106, 149, 0.22);
}

.card-heading {
  margin-bottom: 22rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 136rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fff8fb, #fffdfd);
  border: 1rpx solid rgba(255, 148, 174, 0.1);
  box-sizing: border-box;
}

.stat-val {
  font-size: 46rpx;
  font-weight: 700;
  color: #ff6b95;
}

.stat-key {
  font-size: 24rpx;
  color: #7e8b9d;
  margin-top: 10rpx;
}

.avg-interval {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fbfcff;
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(148, 165, 189, 0.12);
}

.interval-label {
  font-size: 28rpx;
  color: #445166;
}

.interval-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b95;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  min-height: 300rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.bar-wrap {
  position: relative;
  width: 100%;
  height: 188rpx;
  display: flex;
  align-items: flex-end;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.bar-wrap::before {
  content: '';
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 0;
  bottom: 0;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fff4f8, #fffdfd);
}

.bar-fill {
  position: relative;
  width: 100%;
  min-height: 8rpx;
  border-radius: 20rpx 20rpx 14rpx 14rpx;
  background: linear-gradient(180deg, #ff8fa8, #ff6a95);
  box-shadow: 0 12rpx 24rpx rgba(255, 106, 149, 0.18);
}

.bar-label {
  font-size: 20rpx;
  color: #7e8b9d;
  margin-top: 10rpx;
}

.bar-val {
  font-size: 20rpx;
  color: #c44d77;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.daily-list {
  margin-bottom: 24rpx;
}

.daily-item {
  margin-bottom: 20rpx;
}

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.daily-date {
  font-size: 26rpx;
  color: #445166;
}

.daily-stats {
  display: flex;
  gap: 16rpx;
}

.daily-count {
  font-size: 24rpx;
  color: #97a3b4;
}

.daily-amount {
  font-size: 26rpx;
  font-weight: 700;
  color: #ff6b95;
}

.daily-bar {
  height: 14rpx;
  background: #f0f2f6;
  border-radius: 999rpx;
  overflow: hidden;
}

.daily-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff8fa8, #ff6a95);
  border-radius: 999rpx;
}

.insight-card {
  margin-bottom: 24rpx;
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  background: #fbfcff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(148, 165, 189, 0.12);
}

.insight-item:last-child {
  margin-bottom: 0;
}

.insight-icon-img {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
}

.insight-text {
  font-size: 26rpx;
  color: #556276;
  line-height: 1.6;
}

.share-section {
  margin-top: 12rpx;
}

.share-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #ff8fa8, #ff6a95);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(255, 106, 149, 0.28);
}

.page-dark .period-selector,
.page-dark .summary-card,
.page-dark .chart-card,
.page-dark .daily-list,
.page-dark .insight-card {
  background: rgba(25, 35, 52, 0.96);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

.page-dark .period-btn,
.page-dark .stat-item,
.page-dark .avg-interval,
.page-dark .bar-wrap::before,
.page-dark .insight-item {
  background: #111825;
  border-color: rgba(255, 255, 255, 0.12);
}

.page-dark .stat-val,
.page-dark .interval-val,
.page-dark .daily-amount {
  color: #ffd7e1;
}

.page-dark .period-btn,
.page-dark .stat-key,
.page-dark .interval-label,
.page-dark .bar-label,
.page-dark .daily-date,
.page-dark .daily-count,
.page-dark .insight-text {
  color: #c9d3e3 !important;
}

.page-dark .bar-val {
  color: #ffd7e1;
}

.page {
  padding: 24rpx 32rpx 300rpx;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.page-lock {
  height: 100vh;
  overflow: hidden;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.nav-action {
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff4f8;
  color: #c44d77;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.nav-action.disabled {
  background: #f2f4f8;
  color: #b7bfcb;
}

.date-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #253042;
  padding: 0 24rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: #fbfcff;
  border: 1rpx solid rgba(255, 148, 174, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.day-summary {
  margin-bottom: 24rpx;
}

.summary-heading {
  margin-bottom: 22rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 128rpx;
  padding: 24rpx 22rpx;
  background: linear-gradient(180deg, #fff8fb, #fffdfd);
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 148, 174, 0.1);
  box-sizing: border-box;
}

.summary-val {
  font-size: 42rpx;
  font-weight: 700;
  color: #ff6b95;
}

.summary-key {
  font-size: 24rpx;
  color: #7e8b9d;
  margin-top: 8rpx;
}

.records-list {
  margin-bottom: 20rpx;
}

.record-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.record-left {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.type-icon-img {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.record-copy {
  flex: 1;
  min-width: 0;
}

.record-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #253042;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.record-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b95;
}

.record-duration {
  font-size: 24rpx;
  font-weight: 600;
  color: #4f88ff;
  margin-top: 6rpx;
}

.record-time-text {
  display: block;
  font-size: 24rpx;
  color: #7e8b9d;
  margin-top: 10rpx;
}

.record-note-text {
  display: block;
  font-size: 26rpx;
  color: #586579;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eef1f6;
  line-height: 1.6;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}

.interval-text {
  font-size: 22rpx;
  color: #97a3b4;
}

.record-ops {
  display: flex;
  gap: 28rpx;
}

.record-ops text {
  font-size: 26rpx;
  color: #8995a7;
}

.record-ops .danger {
  color: #ef5350;
}

.add-btn-wrap {
  position: fixed;
  bottom: calc(232rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
}

.add-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #ff8fa8, #ff6a95);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 32rpx rgba(255, 106, 149, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  overflow: hidden;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(11, 18, 31, 0.42);
  backdrop-filter: blur(4rpx);
}

.modal-body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  height: 88vh;
  max-height: 92vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #253042;
}

.modal-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8a96a7;
}

.modal-close {
  font-size: 40rpx;
  color: #94a0b2;
  padding: 6rpx 10rpx;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx 32rpx 10rpx;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #445166;
  margin-bottom: 16rpx;
}

.type-selector-scroll {
  width: 100%;
  white-space: nowrap;
}

.type-selector {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  min-height: 116rpx;
  padding: 14rpx 10rpx;
  border-radius: 20rpx;
  background: #f8f2f5;
  box-sizing: border-box;
  flex-shrink: 0;
}

.type-option.active {
  background: rgba(255, 143, 171, 0.14);
}

.type-option-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 10rpx;
}

.type-option-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4f5b6f;
}

.option-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.option-btn {
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #f8f2f5;
  font-size: 26rpx;
  font-weight: 600;
  color: #667387;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.option-btn.active {
  background: rgba(255, 143, 171, 0.14);
  color: #c44d77;
}

.amount-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.preset-btn {
  min-width: 96rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #fff4f8;
  font-size: 26rpx;
  font-weight: 600;
  color: #c44d77;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.preset-btn.active {
  background: #ff8fa8;
  color: #ffffff;
}

.form-input-wrap {
  width: 100%;
  min-width: 0;
}

.form-input,
.time-picker,
.form-textarea {
  display: block;
  width: 100%;
  min-width: 0;
  border: 2rpx solid #eef1f6;
  border-radius: 22rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fbfcff;
  color: #253042;
}

.form-input,
.time-picker {
  height: 92rpx;
  line-height: 92rpx;
}

.form-textarea {
  height: 120rpx;
  padding-top: 22rpx;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eef1f6;
  background: #ffffff;
}

.modal-footer button {
  flex: 1;
}

.form-group:last-child {
  margin-bottom: 8rpx;
}

.page-dark .date-nav,
.page-dark .day-summary,
.page-dark .record-item,
.page-dark .modal-body,
.page-dark .modal-footer {
  background: rgba(25, 35, 52, 0.96);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

.page-dark .nav-action,
.page-dark .date-text,
.page-dark .summary-item,
.page-dark .type-option,
.page-dark .option-btn,
.page-dark .form-input,
.page-dark .time-picker,
.page-dark .form-textarea {
  background: #111825;
  border-color: rgba(255, 255, 255, 0.12);
}

.page-dark .date-text,
.page-dark .summary-val,
.page-dark .type-name,
.page-dark .record-amount,
.page-dark .record-duration,
.page-dark .modal-title,
.page-dark .form-label,
.page-dark .form-input,
.page-dark .form-textarea,
.page-dark .time-picker,
.page-dark .type-option-label {
  color: #eef2fb !important;
}

.page-dark .summary-key,
.page-dark .record-time-text,
.page-dark .record-note-text,
.page-dark .interval-text,
.page-dark .modal-copy {
  color: #a8b4c6 !important;
}

.page-dark .nav-action {
  color: #ffd7e1;
}

.page-dark .nav-action.disabled {
  color: #748196;
}

.page-dark .summary-item {
  background: rgba(255, 255, 255, 0.04);
}

.page-dark .type-option.active,
.page-dark .option-btn.active,
.page-dark .preset-btn.active {
  background: rgba(255, 143, 171, 0.18);
}

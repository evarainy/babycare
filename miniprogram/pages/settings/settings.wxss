.page {
  padding: 24rpx 32rpx 168rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.profile-card,
.section-card {
  margin-bottom: 24rpx;
}

.profile-editor {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  min-width: auto;
  width: auto;
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  border: 4rpx solid rgba(255, 143, 171, 0.18);
  box-shadow: 0 14rpx 28rpx rgba(255, 106, 149, 0.12);
}

.profile-form {
  flex: 1;
  min-width: 0;
}

.profile-name-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #eef1f6;
  border-radius: 22rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin: 14rpx 0 12rpx;
  background: #fbfcff;
  color: #253042;
}

.profile-role {
  font-size: 25rpx;
  color: #445166;
  background: #fff7fa;
  border: 2rpx solid #f7e2ea;
  border-radius: 18rpx;
  padding: 18rpx 18rpx;
  margin-bottom: 10rpx;
}

.profile-family {
  display: block;
}

.profile-save-btn,
.section-btn {
  width: 100%;
}

.section-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.section-head-copy {
  flex: 1;
  min-width: 0;
}

.section-title-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #253042;
}

.section-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7e8b9d;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef1f6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.setting-icon-img {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.setting-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #253042;
}

.setting-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7e8b9d;
  line-height: 1.5;
}

.setting-arrow {
  font-size: 34rpx;
  color: #b0b8c4;
}

.member-count {
  font-size: 24rpx;
  font-weight: 600;
  color: #c44d77;
}

.bot-status {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  background: #fbfcff;
  border: 1rpx solid rgba(148, 165, 189, 0.12);
  border-radius: 18rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c5cdd8;
  margin-right: 12rpx;
}

.status-dot.active {
  background: #2ea85b;
}

.status-text {
  font-size: 26rpx;
  color: #556276;
}

.guide-card {
  background: #fbfcff;
  border: 1rpx solid rgba(148, 165, 189, 0.12);
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  margin-top: 16rpx;
}

.guide-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #445166;
  margin-bottom: 12rpx;
}

.guide-step {
  display: block;
  font-size: 24rpx;
  color: #586579;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

.guide-tip {
  display: block;
  font-size: 22rpx;
  color: #c44d77;
  margin-top: 10rpx;
  line-height: 1.6;
}

.siri-config {
  margin-top: 18rpx;
}

.config-label {
  display: block;
  font-size: 24rpx;
  color: #7e8b9d;
  margin-bottom: 10rpx;
}

.config-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #fbfcff;
  border-radius: 22rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(148, 165, 189, 0.12);
}

.api-url {
  font-size: 22rpx;
  color: #253042;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-btn {
  font-size: 24rpx;
  color: #c44d77;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-weight: 600;
}

.baby-list {
  margin-bottom: 20rpx;
}

.baby-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef1f6;
}

.baby-item:last-child {
  border-bottom: none;
}

.baby-item.active {
  background: linear-gradient(90deg, rgba(255, 143, 171, 0.06), transparent);
}

.baby-item-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.baby-item-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.baby-item-info {
  flex: 1;
  min-width: 0;
}

.baby-item-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.baby-item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #253042;
}

.baby-item-meta {
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}

.baby-item-tag {
  font-size: 20rpx;
  color: #c44d77;
  background: #ffeaf2;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.baby-item-ops {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-left: 12rpx;
}

.baby-item-edit {
  font-size: 24rpx;
  color: #c44d77;
}

.baby-item-delete {
  font-size: 24rpx;
  color: #ef5350;
}

.version-info {
  text-align: center;
  padding: 24rpx 0;
}

.version-text {
  display: block;
  font-size: 26rpx;
  color: #7e8b9d;
}

.version-desc {
  display: block;
  margin-top: 8rpx;
  padding: 0 32rpx;
  line-height: 1.6;
}

.invite-modal,
.join-modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(11, 18, 31, 0.42);
  backdrop-filter: blur(4rpx);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 22rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e7ebf1;
  margin: 0 auto 24rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 700;
  text-align: center;
  color: #253042;
}

.modal-subtitle {
  display: block;
  margin: 12rpx 0 28rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8a96a7;
}

.invite-code-display {
  text-align: center;
  background: linear-gradient(135deg, #fff3f7, #fffdfd);
  border-radius: 28rpx;
  padding: 34rpx;
  margin: 30rpx 0 24rpx;
  border: 1rpx solid rgba(255, 148, 174, 0.14);
}

.invite-code {
  font-size: 72rpx;
  font-weight: 900;
  color: #ff6b95;
  letter-spacing: 16rpx;
}

.invite-tip {
  display: block;
  font-size: 26rpx;
  color: #586579;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.7;
}

.join-input,
.picker-input {
  width: 100%;
  height: 92rpx;
  border: 2rpx solid #eef1f6;
  border-radius: 22rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fbfcff;
  color: #253042;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
}

.join-input {
  text-align: center;
  letter-spacing: 8rpx;
}

.modal-btn {
  margin-top: 16rpx;
}

.field-wrap {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #7e8b9d;
  margin-bottom: 10rpx;
}

.photo-uploader {
  border: 2rpx dashed #f0c7d5;
  border-radius: 22rpx;
  padding: 20rpx;
  background: #fff8fb;
}

.photo-preview,
.photo-placeholder {
  width: 148rpx;
  height: 148rpx;
  border-radius: 24rpx;
}

.photo-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #97a3b4;
  font-size: 24rpx;
  background: #ffffff;
  border: 2rpx dashed #e8edf4;
}

.photo-buttons {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.btn-small {
  min-width: 168rpx;
  height: 72rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.page-dark .profile-card,
.page-dark .section-card,
.page-dark .modal-content {
  background: rgba(25, 35, 52, 0.96);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

.page-dark .profile-name-input,
.page-dark .profile-role,
.page-dark .guide-card,
.page-dark .config-value,
.page-dark .bot-status,
.page-dark .join-input,
.page-dark .picker-input,
.page-dark .photo-uploader {
  background: #111825;
  border-color: rgba(255, 255, 255, 0.12);
}

.page-dark .setting-item,
.page-dark .baby-item {
  border-bottom-color: rgba(255, 255, 255, 0.08);
}

.page-dark .section-title-text,
.page-dark .setting-label,
.page-dark .profile-role,
.page-dark .profile-name-input,
.page-dark .status-text,
.page-dark .api-url,
.page-dark .version-text,
.page-dark .baby-item-name,
.page-dark .modal-title,
.page-dark .join-input,
.page-dark .picker-input {
  color: #eef2fb !important;
}

.page-dark .section-desc,
.page-dark .setting-desc,
.page-dark .text-gray,
.page-dark .version-desc,
.page-dark .guide-step,
.page-dark .config-label,
.page-dark .field-label,
.page-dark .invite-tip,
.page-dark .modal-subtitle {
  color: #a8b4c6 !important;
}

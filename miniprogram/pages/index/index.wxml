<view class="page {{darkMode ? 'page-dark' : ''}}">
  <view class="header">
    <view class="weather-card">
      <view class="weather-fixed-copy">
        <text class="weather-fixed-main">{{weatherInfo.text || '--'}}</text>
        <text class="weather-fixed-sub">{{weatherInfo.temperatureText || '--'}}  {{weatherInfo.humidityText || '--'}}</text>
      </view>
      <image class="weather-icon weather-icon-large" src="{{weatherInfo.iconPath}}" mode="aspectFit" />
    </view>

    <view class="baby-hero" bindtap="goBabyProfile">
      <image class="baby-hero-bg" src="{{babyProfile.photoUrl || userAvatar}}" mode="aspectFill" binderror="onBabyImageError" />
      <view class="baby-hero-overlay"></view>
      <view class="baby-hero-content">
        <view class="baby-main">
          <text class="baby-name">{{babyProfile.name}}</text>
          <text class="baby-age">{{babyProfile.birthday ? ('出生 ' + babyProfile.ageText) : '请在设置页完善生日信息'}}</text>
          <view class="baby-metrics">
            <view class="metric-pill">
              <text class="metric-label">体重</text>
              <text class="metric-value">{{babyProfile.weightG !== '' ? (babyProfile.weightG + 'g') : '未填写'}}</text>
            </view>
            <view class="metric-pill">
              <text class="metric-label">身高</text>
              <text class="metric-value">{{babyProfile.heightCm !== '' ? (babyProfile.heightCm + 'cm') : '未填写'}}</text>
            </view>
          </view>
        </view>
        <image class="baby-avatar" src="{{babyProfile.photoUrl || userAvatar}}" mode="aspectFill" binderror="onBabyImageError" />
      </view>
    </view>

    <view class="summary-cards">
      <view class="summary-card summary-card-combined">
        <view class="summary-card-head">
          <view class="summary-title-inline">
            <text class="summary-top-label">今日喂养总览</text>
            <text class="summary-hint">{{todayDate}}</text>
          </view>
        </view>
        <view class="summary-combined-row">
          <view class="summary-kpi-item">
            <text class="summary-kpi-num">{{todaySummary.totalAmount || 0}}</text>
            <text class="summary-kpi-label">总奶量 ml</text>
          </view>
          <view class="summary-kpi-divider"></view>
          <view class="summary-kpi-item">
            <text class="summary-kpi-num {{intervalWarning ? 'warning' : ''}}">{{intervalText}}</text>
            <text class="summary-kpi-label">距上次间隔</text>
          </view>
        </view>
      </view>

      <view class="summary-card summary-card-milk summary-card-milk-compact">
        <view class="milk-breakdown">
          <view class="milk-item">
            <text class="milk-item-label">奶粉</text>
            <text class="milk-item-value">{{todaySummary.formulaAmount || 0}}ml</text>
          </view>
          <view class="milk-item">
            <text class="milk-item-label">母乳</text>
            <text class="milk-item-value">{{todaySummary.breastMilkAmount || 0}}ml</text>
          </view>
          <view class="milk-item">
            <text class="milk-item-label">亲喂</text>
            <text class="milk-item-value">{{todaySummary.directFeedDurationText || '0分钟'}}</text>
          </view>
          <view class="milk-item">
            <text class="milk-item-label">水量</text>
            <text class="milk-item-value">{{todaySummary.waterAmount || 0}}ml</text>
          </view>
        </view>
      </view>

      <view class="summary-card summary-card-food">
        <view>
          <text class="summary-num">{{todaySummary.foodAmount || 0}}</text>
          <text class="summary-label">辅食摄入 g</text>
        </view>
        <text class="summary-sub-count">{{todaySummary.foodCount || 0}} 次</text>
      </view>
    </view>
  </view>

  <view class="section-panel quick-actions">
    <view class="section-meta">
      <text class="section-kicker">快捷记录</text>
    </view>
    <view class="quick-scroll-wrap">
      <scroll-view
        scroll-x
        class="quick-scroll"
        show-scrollbar="false"
        enhanced="true"
        scroll-with-animation="true"
        scroll-left="{{quickScrollLeft}}"
      >
        <view class="quick-btns">
          <view class="quick-btn" bindtap="quickRecord" data-type="breastfeeding">
            <image class="quick-icon-image" src="/assets/icons/type-breastfeeding.svg" mode="aspectFit" />
            <text class="quick-text">亲喂</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="bottle">
            <image class="quick-icon-image" src="/assets/icons/type-bottle.svg" mode="aspectFit" />
            <text class="quick-text">瓶喂</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="food">
            <image class="quick-icon-image" src="/assets/icons/type-food.svg" mode="aspectFit" />
            <text class="quick-text">辅食</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="supplement">
            <image class="quick-icon-image" src="/assets/icons/type-supplement.svg" mode="aspectFit" />
            <text class="quick-text">补剂</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="medicine">
            <image class="quick-icon-image" src="/assets/icons/type-medicine.svg" mode="aspectFit" />
            <text class="quick-text">药物</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="outdoor">
            <image class="quick-icon-image" src="/assets/icons/type-outdoor.svg" mode="aspectFit" />
            <text class="quick-text">户外</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="swimming">
            <image class="quick-icon-image" src="/assets/icons/type-swimming.svg" mode="aspectFit" />
            <text class="quick-text">游泳</text>
          </view>
          <view class="quick-btn" bindtap="quickRecord" data-type="diaper">
            <image class="quick-icon-image" src="/assets/icons/type-diaper.svg" mode="aspectFit" />
            <text class="quick-text">尿布</text>
          </view>
        </view>
      </scroll-view>
      <view class="quick-scroll-fade"></view>
    </view>
  </view>

  <view class="section-panel voice-section">
    <view class="section-meta">
      <text class="section-kicker">文字记录</text>
    </view>
    <view class="voice-input-area">
      <input
        class="voice-input"
        placeholder="例如：喝了120毫升奶粉，半小时前游泳15分钟，去公园晒太阳"
        placeholder-style="color: #A2ADBE;"
        value="{{voiceText}}"
        bindinput="onVoiceInput"
        confirm-type="send"
        bindconfirm="submitVoiceText"
      />
      <view class="voice-btn" bindtap="submitVoiceText">
        <text class="voice-btn-text">发送</text>
      </view>
    </view>
  </view>

  <view class="section-panel timeline-section">
    <view class="flex-between timeline-header">
      <text class="section-kicker">今日时间轴</text>
      <text class="view-all" bindtap="goRecord">查看全部</text>
    </view>

    <view wx:if="{{todayRecords.length === 0}}" class="empty-state">
      <text>今天还没有记录</text>
      <text class="text-small text-gray">可以从上方快捷记录或语音输入开始</text>
    </view>

    <view class="timeline" wx:else>
      <view class="timeline-item" wx:for="{{todayRecords}}" wx:key="_id">
        <view class="timeline-dot {{item.type}}"></view>
        <view class="timeline-content card">
          <view class="flex-between record-head">
            <view class="record-main">
              <image class="type-icon-img" src="{{item.typeIconPath}}" mode="aspectFit" />
              <view class="record-title-group">
                <view class="record-title-row">
                  <text class="record-type">{{item.typeLabel}}</text>
                  <view class="tag tag-pink" wx:if="{{item.feedingType}}">{{item.feedingType}}</view>
                  <view class="tag tag-pink" wx:if="{{item.itemName}}">{{item.itemName}}</view>
                  <view class="tag tag-blue" wx:if="{{item.side}}">{{item.sideLabel}}</view>
                </view>
                <text class="record-time">{{item.timeText}}</text>
              </view>
            </view>
            <text class="record-detail" wx:if="{{item.amountText || item.duration}}">{{item.amountText || (item.duration + '分钟')}}</text>
          </view>

          <view class="record-subline" wx:if="{{item.amountText && item.duration}}">
            <text>{{item.duration}} 分钟</text>
          </view>
          <text class="record-note text-gray text-small" wx:if="{{item.note}}">{{item.note}}</text>
          <view class="record-actions">
            <text class="action-btn" bindtap="editRecord" data-id="{{item._id}}">编辑</text>
            <text class="action-btn danger" bindtap="deleteRecord" data-id="{{item._id}}">删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-panel pending-section" wx:if="{{pendingRecords.length > 0}}">
    <view class="section-meta">
      <text class="section-kicker">待确认记录</text>
    </view>
    <view class="pending-item card" wx:for="{{pendingRecords}}" wx:key="_id">
      <view class="flex-between pending-head">
        <view class="pending-main">
          <image class="type-icon-img" src="{{item.typeIconPath}}" mode="aspectFit" />
          <view class="pending-copy">
            <text class="pending-title">{{item.typeLabel}} {{item.itemName || ''}}</text>
            <text class="pending-desc">{{item.amountText}} {{item.sideLabel}}</text>
          </view>
        </view>
        <view class="flex-row pending-actions">
          <text class="action-btn confirm" bindtap="confirmRecord" data-id="{{item._id}}">确认</text>
          <text class="action-btn danger" bindtap="deleteRecord" data-id="{{item._id}}">删除</text>
        </view>
      </view>
      <text class="text-small text-gray">来源：{{item.source === 'wechat_bot' ? '微信群' : 'Siri'}}</text>
    </view>
  </view>
</view>

<view class="quick-modal" wx:if="{{showQuickModal}}">
  <view class="modal-mask" bindtap="closeModal"></view>
  <view class="modal-content">
    <view class="modal-handle"></view>
    <view class="modal-title">{{quickModalTitle}}</view>
    <text class="modal-subtitle">完善关键信息后即可快速保存</text>

    <view class="amount-section" wx:if="{{quickModalType === 'breastfeeding'}}">
      <text class="amount-label">亲喂侧别</text>
      <view class="side-btns">
        <view class="side-btn {{quickSide === 'left' ? 'active' : ''}}" bindtap="selectSide" data-side="left">左侧</view>
        <view class="side-btn {{quickSide === 'right' ? 'active' : ''}}" bindtap="selectSide" data-side="right">右侧</view>
        <view class="side-btn {{quickSide === 'both' ? 'active' : ''}}" bindtap="selectSide" data-side="both">双侧</view>
      </view>
      <text class="amount-label">时长（分钟）</text>
      <view class="amount-btns">
        <view class="amount-btn" wx:for="{{durationPresets}}" wx:key="*this" bindtap="selectDuration" data-duration="{{item}}">{{item}}</view>
      </view>
      <input class="amount-input" type="number" placeholder="输入时长" value="{{quickDuration}}" bindinput="onDurationInput" />
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'bottle'}}">
      <text class="amount-label">瓶喂类型</text>
      <view class="side-btns">
        <view class="side-btn {{quickBottleType === '奶粉' ? 'active' : ''}}" bindtap="selectBottleType" data-btype="奶粉">奶粉</view>
        <view class="side-btn {{quickBottleType === '母乳' ? 'active' : ''}}" bindtap="selectBottleType" data-btype="母乳">母乳</view>
        <view class="side-btn {{quickBottleType === '水' ? 'active' : ''}}" bindtap="selectBottleType" data-btype="水">水</view>
        <view class="side-btn {{quickBottleType === '补剂' ? 'active' : ''}}" bindtap="selectBottleType" data-btype="补剂">补剂</view>
      </view>
      <text class="amount-label">奶量（ml）</text>
      <view class="amount-btns">
        <view class="amount-btn" wx:for="{{amountPresets}}" wx:key="*this" bindtap="selectAmount" data-amount="{{item}}">{{item}}</view>
      </view>
      <input class="amount-input" type="number" placeholder="输入奶量" value="{{quickAmount}}" bindinput="onAmountInput" />
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'food'}}">
      <text class="amount-label">辅食重量（g）</text>
      <view class="amount-btns">
        <view class="amount-btn" wx:for="{{foodPresets}}" wx:key="*this" bindtap="selectAmount" data-amount="{{item}}">{{item}}</view>
      </view>
      <input class="amount-input" type="number" placeholder="输入克数" value="{{quickAmount}}" bindinput="onAmountInput" />
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'supplement'}}">
      <text class="amount-label">补剂名称</text>
      <view class="side-btns">
        <view class="side-btn {{quickItemName === item ? 'active' : ''}}" wx:for="{{supplementNameOptions}}" wx:key="*this" bindtap="selectQuickItemName" data-name="{{item}}">{{item}}</view>
      </view>
      <text class="amount-label">单位</text>
      <view class="side-btns">
        <view class="side-btn {{quickUnit === item ? 'active' : ''}}" wx:for="{{unitOptions}}" wx:key="*this" bindtap="selectQuickUnit" data-unit="{{item}}">{{item}}</view>
      </view>
      <input class="amount-input" type="digit" placeholder="输入用量" value="{{quickAmount}}" bindinput="onAmountInput" />
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'medicine'}}">
      <text class="amount-label">药物名称</text>
      <input class="amount-input" placeholder="输入药物名称" value="{{quickItemName}}" bindinput="onQuickItemNameInput" />
      <text class="amount-label">单位</text>
      <view class="side-btns">
        <view class="side-btn {{quickUnit === item ? 'active' : ''}}" wx:for="{{unitOptions}}" wx:key="*this" bindtap="selectQuickUnit" data-unit="{{item}}">{{item}}</view>
      </view>
      <input class="amount-input" type="digit" placeholder="输入用量" value="{{quickAmount}}" bindinput="onAmountInput" />
      <text class="amount-label">备注</text>
      <textarea class="amount-input amount-textarea" placeholder="输入备注（可选）" value="{{quickNote}}" bindinput="onQuickNoteInput" maxlength="120" auto-height="true"></textarea>
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'outdoor'}}">
      <text class="amount-label">户外事件</text>
      <input class="amount-input" placeholder="例如 晒太阳 / 公园散步 / 小区遛弯" value="{{quickEvent}}" bindinput="onQuickEventInput" />
      <text class="amount-label">记录时间</text>
      <picker mode="time" value="{{quickTimeStr}}" bindchange="onQuickTimeChange">
        <view class="amount-input picker-like">{{quickTimeStr || '选择时间'}}</view>
      </picker>
      <text class="amount-label">备注</text>
      <textarea class="amount-input amount-textarea" placeholder="输入备注（可选）" value="{{quickNote}}" bindinput="onQuickNoteInput" maxlength="120" auto-height="true"></textarea>
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'swimming'}}">
      <text class="amount-label">时长（分钟）</text>
      <view class="amount-btns">
        <view class="amount-btn" wx:for="{{durationPresets}}" wx:key="*this" bindtap="selectDuration" data-duration="{{item}}">{{item}}</view>
      </view>
      <input class="amount-input" type="number" placeholder="输入时长" value="{{quickDuration}}" bindinput="onDurationInput" />
    </view>

    <view class="amount-section" wx:if="{{quickModalType === 'supplement' || quickModalType === 'medicine'}}">
      <text class="amount-label">记录时间</text>
      <picker mode="time" value="{{quickTimeStr}}" bindchange="onQuickTimeChange">
        <view class="amount-input picker-like">{{quickTimeStr || '选择时间'}}</view>
      </picker>
    </view>

    <view class="modal-actions">
      <button class="btn-secondary" bindtap="closeModal">取消</button>
      <button class="btn-primary" bindtap="submitQuickRecord">确认记录</button>
    </view>
  </view>
</view>

<voice-floating-button bind:recordsuccess="onVoiceRecordSuccess" />
<view class="voice-fab-inline-label">语音录入</view>
